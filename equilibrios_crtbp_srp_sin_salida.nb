                    SubscriptBox[
                    OverscriptBox[
                    StyleBox["r", "TI"], "\[RightVector]"], 
                    RowBox[{
                    StyleBox["p", "TI"], 
                    StyleBox["s", "TI"]}]], 
                    "\[DoubleVerticalBar]\[DoubleVerticalBar]", "\[Del]", 
                    StyleBox["V", "TI"], 
                    SuperscriptBox["\[DoubleVerticalBar]", "3"]}], 
                    RowBox[{"(", 
