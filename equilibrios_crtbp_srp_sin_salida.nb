Cell[BoxData[
 RowBox[{
  RowBox[{"beta", "[", 
   RowBox[{"x_", ",", "y_", ",", "z_", ",", "mu_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"r1", "=", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"x", "+", "mu"}], ")"}], "^", "2"}], "+", 
         RowBox[{"y", "^", "2"}], "+", 
         RowBox[{"z", "^", "2"}]}], "]"}]}], ",", 
      RowBox[{"r2", "=", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"x", "-", "1", "+", "mu"}], ")"}], "^", "2"}], "+", 
         RowBox[{"y", "^", "2"}], "+", 
         RowBox[{"z", "^", "2"}]}], "]"}]}], ",", "g"}], "}"}], ",", 
    RowBox[{"Piecewise", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"Norm", "[", 
            RowBox[{"g", "=", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"x", "-", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"1", "-", "mu"}], ")"}], 
                 RowBox[{
                  RowBox[{"(", 
                   RowBox[{"x", "+", "mu"}], ")"}], "/", 
                  RowBox[{"r1", "^", "3"}]}]}], "-", 
                RowBox[{"mu", 
                 RowBox[{
                  RowBox[{"(", 
                   RowBox[{"x", "-", "1", "+", "mu"}], ")"}], "/", 
                  RowBox[{"r2", "^", "3"}]}]}]}], ",", 
               RowBox[{"y", "-", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"1", "-", "mu"}], ")"}], 
                 RowBox[{"y", "/", 
                  RowBox[{"r1", "^", "3"}]}]}], "-", 
                RowBox[{"mu", "*", 
                 RowBox[{"y", "/", 
                  RowBox[{"r2", "^", "3"}]}]}]}], ",", 
               RowBox[{
                RowBox[{
                 RowBox[{"-", 
                  RowBox[{"(", 
                   RowBox[{"1", "-", "mu"}], ")"}]}], 
                 RowBox[{"z", "/", 
                  RowBox[{"r1", "^", "3"}]}]}], "-", 
                RowBox[{"mu", "*", 
                 RowBox[{"z", "/", 
                  RowBox[{"r2", "^", "3"}]}]}]}]}], "}"}]}], "]"}], "^", 
           "3"}], "*", 
          RowBox[{
           RowBox[{"r1", "^", "4"}], "/", 
           RowBox[{"(", 
            RowBox[{"(", 
             RowBox[{"1", "-", "mu"}], ")"}], ")"}]}]}], ",", 
         RowBox[{
          RowBox[{"S", "[", 
           RowBox[{"x", ",", "y", ",", "z", ",", "mu"}], "]"}], ">", "0"}]}], 
        "}"}], "}"}], ",", "Infinity"}], "]"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.9898942414712315`*^9, 3.989894261024847*^9}, {
