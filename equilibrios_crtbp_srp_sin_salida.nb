Cell["Posiciones de los puntos de Euler y Lagrange", "Text",
 CellChangeTimes->{{3.990845582738577*^9, 3.99084560134956*^9}, {
  3.9908456465897026`*^9, 
  3.9908456522549*^9}},ExpressionUUID->"26d82c37-a190-294a-8245-29becfb571ef"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"L1x", "[", "mu_", "]"}], ":=", 
  RowBox[{"x", " ", "/.", " ", 
   RowBox[{"FindRoot", "[", 
    RowBox[{
     RowBox[{"S", "[", 
      RowBox[{"x", ",", "0", ",", "0", ",", "mu"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0.5"}], "}"}]}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"L2x", "[", "mu_", "]"}], ":=", 
  RowBox[{"x", " ", "/.", " ", 
   RowBox[{"FindRoot", "[", 
    RowBox[{
     RowBox[{"S", "[", 
      RowBox[{"x", ",", "0", ",", "0", ",", "mu"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "1"}], "}"}]}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"L3x", "[", "mu_", "]"}], ":=", 
  RowBox[{"x", " ", "/.", " ", 
   RowBox[{"FindRoot", "[", 
    RowBox[{
     RowBox[{"S", "[", 
      RowBox[{"x", ",", "0", ",", "0", ",", "mu"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "1"}]}], "}"}]}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"L1", "[", "mu_", "]"}], ":=", " ", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"L1x", "[", "mu", "]"}], ",", "0", ",", "0"}], "}"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"L2", "[", "mu_", "]"}], ":=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"L2x", "[", "mu", "]"}], ",", "0", ",", "0"}], "}"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"L3", "[", "mu_", "]"}], ":=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"L3x", "[", "mu", "]"}], ",", "0", ",", "0"}], "}"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"L4", "[", "mu_", "]"}], ":=", " ", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{
     RowBox[{"1", "/", "2"}], "-", "mu"}], ",", " ", 
    RowBox[{
     RowBox[{"Sqrt", "[", "3", "]"}], "/", "2"}], ",", "0"}], "}"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"L5", "[", "mu_", "]"}], ":=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{
     RowBox[{"1", "/", "2"}], "-", "mu"}], ",", " ", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"Sqrt", "[", "3", "]"}]}], "/", "2"}], ",", "0"}], 
   "}"}]}]}], "Input",
 CellChangeTimes->{{3.9908458529060764`*^9, 3.990846080806677*^9}, 
   3.9908464274946003`*^9, {3.990847224543663*^9, 3.990847266279104*^9}, {
   3.9908475002039967`*^9, 3.990847500490549*^9}},
 CellLabel->"In[5]:=",ExpressionUUID->"9307a6ac-37a0-7145-8688-c781fd99a501"],

Cell[TextData[{
 "S ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[LongEqual]", 
         RowBox[{"<", 
           RowBox[{
             SubscriptBox[
              OverscriptBox[
               StyleBox["r", "TI"], "\[RightVector]"], 
              RowBox[{
                StyleBox["p", "TI"], 
                StyleBox["s", "TI"]}]], ",", "-", "\[Del]", 
             StyleBox["V", "TI"]}], ">"}]}], TraditionalForm], "errors" -> {},
      "input" -> "= \\left<\\vec{r}_{ps}, -\\nabla V \\right>", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9068d255-3980-5541-b3f7-183f891ec9fc"],
 "   "
}], "Text",
 CellChangeTimes->{{3.9908438839710445`*^9, 3.9908439486221046`*^9}, {
  3.9908464351052876`*^9, 
  3.9908464365281334`*^9}},ExpressionUUID->"05b67263-cf89-6a49-8acc-\
f2ed28b69fe6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"S", "[", 
   RowBox[{"x_", ",", "y_", ",", "z_", ",", "mu_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"r1", ",", "r2"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"r1", "=", 
      RowBox[{"Sqrt", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"x", "+", "mu"}], ")"}], "^", "2"}], "+", 
        RowBox[{"y", "^", "2"}], "+", 
        RowBox[{"z", "^", "2"}]}], "]"}]}], ";", "\n", "     ", 
     RowBox[{"r2", "=", 
      RowBox[{"Sqrt", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"x", "-", "1", "+", "mu"}], ")"}], "^", "2"}], "+", 
        RowBox[{"y", "^", "2"}], "+", 
        RowBox[{"z", "^", "2"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "x"}], " ", 
       RowBox[{"(", 
        RowBox[{"x", "+", "mu"}], ")"}]}], "-", 
      RowBox[{"y", "^", "2"}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", "mu"}], ")"}], "/", "r1"}], "+", 
      RowBox[{"mu", " ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"x", "+", "mu"}], ")"}], " ", 
           RowBox[{"(", 
            RowBox[{"x", "-", "1", "+", "mu"}], ")"}]}], "+", 
          RowBox[{"y", "^", "2"}], "+", 
          RowBox[{"z", "^", "2"}]}], ")"}], "/", 
        RowBox[{"r2", "^", "3"}]}]}]}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.989908693215271*^9, 3.989908703321066*^9}},
 CellLabel->"In[13]:=",ExpressionUUID->"0f3d658c-3b5e-9d44-813c-c8389ceefdb1"],

Cell[TextData[{
 "En la secci\[OAcute]n 2.3 de la memoria vimos que ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Beta]", "\[LongEqual]", 
         FractionBox[
          RowBox[{"\[DoubleVerticalBar]", 
            SubscriptBox[
             OverscriptBox[
              StyleBox["r", "TI"], "\[RightVector]"], 
             RowBox[{
               StyleBox["p", "TI"], 
               StyleBox["s", "TI"]}]], 
            "\[DoubleVerticalBar]\[DoubleVerticalBar]", "\[Del]", 
            StyleBox["V", "TI"], 
            SuperscriptBox["\[DoubleVerticalBar]", "3"]}], 
          RowBox[{
            SuperscriptBox[
             RowBox[{"<", 
               RowBox[{
                 SubscriptBox[
                  OverscriptBox[
                   StyleBox["r", "TI"], "\[RightVector]"], 
                  RowBox[{
                    StyleBox["p", "TI"], 
                    StyleBox["s", "TI"]}]], ",", "-", "\[Del]", 
                 StyleBox["V", "TI"]}], ">"}], "2"], "(", 
            RowBox[{"1", "-", "\[Mu]"}], ")"}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\beta = \\frac{\\|\\vec{r}_{ps}\\| \\|\\nabla \
V\\|^3}{\\left<\\vec{r}_{ps}, -\\nabla V\\right>^2 (1-\\mu)}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f8312e39-8cf5-2242-84a1-f7cce7339523"],
 " ,  que puede escribirse como ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Beta]", "\[LongEqual]", 
         FractionBox[
          RowBox[{"\[DoubleVerticalBar]", 
            SubscriptBox[
             OverscriptBox[
              StyleBox["r", "TI"], "\[RightVector]"], 
             RowBox[{
               StyleBox["p", "TI"], 
               StyleBox["s", "TI"]}]], 
            "\[DoubleVerticalBar]\[DoubleVerticalBar]", "\[Del]", 
            StyleBox["V", "TI"], 
            SuperscriptBox["\[DoubleVerticalBar]", "3"]}], 
          RowBox[{
            SuperscriptBox[
             StyleBox["S", "TI"], "2"], "(", 
            RowBox[{"1", "-", "\[Mu]"}], ")"}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\beta = \\frac{\\|\\vec{r}_{ps}\\| \\|\\nabla V\\|^3}{S^2 (1-\\mu)}", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a75db600-21ce-d748-8c8b-422289b06995"],
 ".  Por cuestiones num\[EAcute]ricas, dibujaremos las superficies de nivel \
de ",
