Cell["\<\
En segundo lugar, definimos la funci\[OAcute]n del producto escalar \
(prodesc), las componentes del vector normal (nx, ny y nz) y las componentes \
de la aceleraci\[OAcute]n debida a la presi\[OAcute]n de radiaci\[OAcute]n \
solar (ax, ay y az).\
\>", "Text",
 CellChangeTimes->{
  3.990705631503092*^9, {3.9907056657815437`*^9, 3.990705666157812*^9}, {
   3.9907057037410088`*^9, 3.990705721965721*^9}, {3.990797201556675*^9, 
   3.9907973167066593`*^9}, {3.99079778101775*^9, 
   3.9907978090593414`*^9}},ExpressionUUID->"96707a59-05ff-934b-94b7-\
23c71f75e904"],

Cell[BoxData[
 RowBox[{
  RowBox[{"prodesc", "[", 
   RowBox[{"x_", ",", "y_", ",", "z_", ",", "alpha_", ",", "delta_"}], "]"}], 
  ":=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"Sqrt", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"x", "+", "mu"}], ")"}], "^", "2"}], "+", 
            RowBox[{"y", "^", "2"}]}], "]"}], "^", "2"}], "*", 
         RowBox[{"Cos", "[", "alpha", "]"}]}], "+", 
        RowBox[{"z", "^", "2"}]}], ")"}], "*", 
      RowBox[{"Cos", "[", "delta", "]"}]}], "+", 
     RowBox[{"z", "*", 
      RowBox[{"Sqrt", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"x", "+", "mu"}], ")"}], "^", "2"}], "+", 
        RowBox[{"y", "^", "2"}]}], "]"}], "*", 
      RowBox[{"(", 
       RowBox[{"1", "-", 
        RowBox[{"Cos", "[", "alpha", "]"}]}], ")"}], "*", 
      RowBox[{"Sin", "[", "delta", "]"}]}]}], ")"}], "/", 
   RowBox[{
    RowBox[{"Sqrt", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"x", "+", "mu"}], ")"}], "^", "2"}], "+", 
      RowBox[{"y", "^", "2"}], "+", 
      RowBox[{"z", "^", "2"}]}], "]"}], "^", "2"}]}]}]], "Input",
 CellChangeTimes->{{3.9891287894091625`*^9, 3.989128908940405*^9}, 
   3.9891293116047153`*^9},
 CellLabel->"In[1]:=",ExpressionUUID->"8d2c162b-3759-5141-b0f9-ead558b5197c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"nx", "[", 
   RowBox[{"x_", ",", "y_", ",", "z_", ",", "alpha_", ",", "delta_"}], "]"}], 
  ":=", 
  RowBox[{
   RowBox[{"1", "/", 
    RowBox[{"Sqrt", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"x", "+", "mu"}], ")"}], "^", "2"}], "+", 
      RowBox[{"y", "^", "2"}], "+", 
      RowBox[{"z", "^", "2"}]}], "]"}]}], "*", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"x", "+", "mu"}], ")"}], "*", 
      RowBox[{"Cos", "[", "alpha", "]"}], "*", 
      RowBox[{"Cos", "[", "delta", "]"}]}], "-", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"x", "+", "mu"}], ")"}], "*", 
      RowBox[{"z", "/", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"x", "+", "mu"}], ")"}], "^", "2"}], "+", 
         RowBox[{"y", "^", "2"}]}], "]"}]}], "*", 
      RowBox[{"Cos", "[", "alpha", "]"}], "*", 
      RowBox[{"Sin", "[", "delta", "]"}]}], "-", 
     RowBox[{"y", "*", 
      RowBox[{"Sin", "[", "alpha", "]"}], "*", 
      RowBox[{"Cos", "[", "delta", "]"}]}], "+", 
     RowBox[{"y", "*", 
      RowBox[{"z", "/", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"x", "+", "mu"}], ")"}], "^", "2"}], "+", 
         RowBox[{"y", "^", "2"}]}], "]"}]}], "*", 
      RowBox[{"Sin", "[", "alpha", "]"}], "*", 
      RowBox[{"Sin", "[", "delta", "]"}]}]}], ")"}]}]}]], "Input",
 CellChangeTimes->{{3.9891289559980583`*^9, 3.9891291060431995`*^9}, 
