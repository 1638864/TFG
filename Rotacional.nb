Cell[TextData[{
 "En tercer lugar, calculamos las componentes de  ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], 
         StyleBox["o", "TI"], 
         StyleBox["t", "TI"], 
         RowBox[{"(", 
           SubscriptBox[
            OverscriptBox[
             StyleBox["a", "TI"], "\[RightVector]"], 
            RowBox[{
              StyleBox["S", "TI"], 
              StyleBox["R", "TI"], 
              StyleBox["P", "TI"]}]], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> "rot(\\vec{a}_{SRP})", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7a1fb23c-d0b0-e34a-b612-0b447c206ec0"],
 ".  Denotamos por eq1",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[LongEqual]", 
         FractionBox[
          RowBox[{"\[PartialD]", 
            SubscriptBox[
             StyleBox["a", "TI"], 
             StyleBox["y", "TI"]]}], 
          RowBox[{"\[PartialD]", 
            StyleBox["x", "TI"]}]], "-", 
         FractionBox[
          RowBox[{"\[PartialD]", 
            SubscriptBox[
             StyleBox["a", "TI"], 
             StyleBox["x", "TI"]]}], 
          RowBox[{"\[PartialD]", 
            StyleBox["y", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "=\\frac{\\partial a_y}{\\partial x}-\\frac{\\partial a_x}{\\partial y}",
      "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "cb89bfe5-8661-f248-9419-b7b994a2f8a7"],
 " , eq2=",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox[
          RowBox[{"\[PartialD]", 
            SubscriptBox[
             StyleBox["a", "TI"], 
             StyleBox["y", "TI"]]}], 
          RowBox[{"\[PartialD]", 
            StyleBox["z", "TI"]}]], "-", 
         FractionBox[
          RowBox[{"\[PartialD]", 
            SubscriptBox[
             StyleBox["a", "TI"], 
             StyleBox["z", "TI"]]}], 
          RowBox[{"\[PartialD]", 
