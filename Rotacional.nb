Cell[TextData[{
 "En primer lugar, recordamos que el objetivo de este archivo es encontrar \
los valores de ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Alpha]", ",", "\[Delta]", "\[Element]", 
         RowBox[{"[", 
           RowBox[{
             FractionBox[
              RowBox[{"-", "\[Pi]"}], "2"], ",", 
             FractionBox["\[Pi]", "2"]}], "]"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\alpha, \\delta \\in [\\frac{-\\pi}{2}, \\frac{\\pi}{2}]", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "28cd89a5-cea4-f84c-82a2-72c57bc81909"],
 " para los cuales ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], 
         StyleBox["o", "TI"], 
         StyleBox["t", "TI"], 
         RowBox[{"(", 
           SubscriptBox[
            OverscriptBox[
             StyleBox["a", "TI"], "\[RightVector]"], 
            RowBox[{
              StyleBox["S", "TI"], 
              StyleBox["R", "TI"], 
              StyleBox["P", "TI"]}]], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> "rot(\\vec{a}_{SRP})", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "925dc4d8-08e4-c345-b070-3aad4d5a5647"],
 " en los puntos ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"(", 
           RowBox[{"-", "\[Mu]", ",", "0", ",", "0"}], ")"}], ",", 
         RowBox[{"(", 
           RowBox[{"-", "\[Mu]", ",", "1", ",", "1"}], ")"}]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "(-\\mu, 0,0), (-\\mu,1,1)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1a849a3a-6551-4244-8581-f7a797f0b86d"],
 " y ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"(", 
         RowBox[{"-", "\[Mu]", ",", "1", ",", "0"}], ")"}], TraditionalForm], 
