Cell[BoxData[
 RowBox[{"-", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Sin", "[", "alpha", "]"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           SuperscriptBox["z", "2"], "+", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              SuperscriptBox["mu", "2"], "+", 
              RowBox[{"2", " ", "mu", " ", "x"}], "+", 
              SuperscriptBox["x", "2"], "+", 
              SuperscriptBox["y", "2"]}], ")"}], " ", 
            RowBox[{"Cos", "[", "alpha", "]"}]}]}], ")"}], " ", 
         RowBox[{"Cos", "[", "delta", "]"}]}], "-", 
        RowBox[{
         SqrtBox[
          RowBox[{
           SuperscriptBox["mu", "2"], "+", 
           RowBox[{"2", " ", "mu", " ", "x"}], "+", 
           SuperscriptBox["x", "2"], "+", 
           SuperscriptBox["y", "2"]}]], " ", "z", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], "+", 
           RowBox[{"Cos", "[", "alpha", "]"}]}], ")"}], " ", 
         RowBox[{"Sin", "[", "delta", "]"}]}]}], ")"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         SqrtBox[
          RowBox[{
           SuperscriptBox["mu", "2"], "+", 
           RowBox[{"2", " ", "mu", " ", "x"}], "+", 
           SuperscriptBox["x", "2"], "+", 
